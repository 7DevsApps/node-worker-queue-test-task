{
  "name": "async-job-system",
  "version": "1.0.0",
  "description": "Async job processing system with REST API, PostgreSQL queue, BullMQ worker, and exponential backoff retry",
  "scripts": {
    "build": "tsc",
    "start:api": "ts-node src/api/server.ts",
    "start:worker": "ts-node src/worker/worker.ts",
    "migrate": "ts-node src/db/migrate.ts",
    "dev:api": "ts-node-dev --respawn src/api/server.ts",
    "dev:worker": "ts-node-dev --respawn src/worker/worker.ts",
    "test": "jest --verbose"
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "ioredis": "^5.4.1",
    "pg": "^8.13.0",
    "pino": "^9.4.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.5.0",
    "@types/pg": "^8.11.10",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.6.2"
  }
}
